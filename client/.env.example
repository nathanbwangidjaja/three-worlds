# Copy this file to client/.env and fill in your values.

# --- multiplayer server ---
VITE_SERVER_URL=ws://localhost:2567
# For production:
# VITE_SERVER_URL=wss://your-server.onrender.com

# --- Google Photorealistic 3D Tiles (optional, makes the world photoreal) ---
# 1. console.cloud.google.com → create/select a project (billing must be on)
# 2. "APIs & Services" → enable **Map Tiles API**
# 3. "Credentials" → Create credentials → API key → paste below
# 4. Recommended: restrict the key to HTTP referrers (localhost:5173 + your
#    deployed domain) since it ships to the browser.
VITE_GOOGLE_MAPS_API_KEY=
